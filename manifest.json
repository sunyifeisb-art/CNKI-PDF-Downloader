{
  "name": "CNKI论文PDF批量下载助手",
  "version": "0.1.0",
  "manifest_version": 3,
  "description": "知网文献快捷下载助手。下载前提是账号本身具备知网下载权限，插件仅提供快捷下载、抓链与整理能力。",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "downloads",
    "tabs",
    "activeTab",
    "scripting",
    "sidePanel"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*/*"
      ],
      "js": [
        "content/main.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "CNKI论文PDF批量下载助手",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
